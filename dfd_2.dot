digraph DFD_Level_2 {
    rankdir=LR;
    node [fontname="Arial"];
    edge [fontname="Arial", fontsize=10];
    
    // Input / Output Boundaries
    InputBuffer [shape=plaintext, label="Incoming Image Buffer\n(From 2.0)"];
    OutputData [shape=plaintext, label="Final JSON Object\n(To 4.0)"];
    Mode [shape=note, style=filled, fillcolor=lightyellow, label="D1: App State"];
    
    // Processes
    P3_1 [shape=circle, style=filled, fillcolor=lightblue, label="3.1\nInference\nRouter"];
    P3_2 [shape=circle, style=filled, fillcolor=lightgreen, label="3.2\nYOLOv8\nObject Detection"];
    P3_3 [shape=circle, style=filled, fillcolor=lightgreen, label="3.3\nGoogle ML Kit\nText Extraction"];
    P3_4 [shape=circle, style=filled, fillcolor=lightblue, label="3.4\nSpatial Math\nCalculator"];
    P3_5 [shape=circle, style=filled, fillcolor=lightblue, label="3.5\nString\nAggregator"];
    
    // Flows
    InputBuffer -> P3_1;
    Mode -> P3_1 [label=" Check Status "];
    
    P3_1 -> P3_2 [label=" Route to TFJS\n(Safety Mode) "];
    P3_1 -> P3_3 [label=" Route to Native Bridge\n(OCR Mode) "];
    
    P3_2 -> P3_4 [label=" Array of Bounding Boxes "];
    P3_3 -> P3_5 [label=" Raw String Arrays "];
    
    P3_4 -> P3_5 [label=" Translated Coordinates\n(e.g. Near Center) "];
    P3_5 -> OutputData [label=" Aggregated Text\nFor TTS "];
}
